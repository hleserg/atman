# =============================================================================
# Atman — конфигурация деплоя
# Этот файл — в git. Секреты (пароли, ключи) — НЕ здесь.
# Секреты генерируются автоматически в ~/.atman/.secrets
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_VERSION=16
POSTGRES_USER=atman
POSTGRES_DB=atman
POSTGRES_PORT=5432

# ── LLM endpoint (общий для user-agent и reflection) ──────────────────────────
# Один OpenAI-compat endpoint (по умолчанию llama-server :8081 с gemma4).
# Поднимается оператором отдельно от этого скрипта — см. atman_agent_cli/RUNBOOK.md.
ATMAN_LLM_BASE_URL=http://localhost:8081/v1
LLM_MODEL=gemma4

# ── Embeddings + reranker — native FlagEmbedding (CPU lazy) ───────────────────
EMBEDDING_BACKEND=flag
EMBEDDING_FLAG_MODEL=BAAI/bge-m3

# Размерность векторов (соответствует bge-m3 → 1024 dims)
VECTOR_DIM=1024

# ── Qdrant (по умолчанию ПРОПУСКАЕТСЯ; Atman 2026 использует pgvector) ────────
# Включить: ATMAN_USE_QDRANT=1 перед запуском setup.sh.
ATMAN_USE_QDRANT=0
QDRANT_VERSION=latest
QDRANT_PORT=6333
QDRANT_COLLECTION_FACTS=atman_facts
QDRANT_COLLECTION_EXPERIENCES=atman_experiences

# ── Ollama (УСТАРЕВШЕЕ; не используется в коде) ───────────────────────────────
# Оставлено для миграции старых конфигов. Удалите при следующей чистке.
# OLLAMA_LLM_MODEL=gemma3:27b-it-qat
# OLLAMA_EMBED_MODEL=bge-m3
# OLLAMA_KEEP_ALIVE=5m
# OLLAMA_FLASH_ATTENTION=1
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_LOADED_MODELS=2
