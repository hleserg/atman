# Atman — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# =============================================================================
# Required — LLM
# =============================================================================

# Base URL of an OpenAI-compatible LLM endpoint (llama-server, Ollama, etc.)
ATMAN_LLM_BASE_URL=http://localhost:8081/v1

# Model name to use for reflections and the agent
ATMAN_LLM_MODEL=gemma3:27b-it-qat

# API key for the LLM endpoint (leave as-is for local llama-server)
ATMAN_LLM_API_KEY=sk-no-key

# =============================================================================
# PostgreSQL (required when ATMAN_MEMORY_BACKEND=postgres)
# =============================================================================

# Full DSN — takes precedence over individual params below
# ATMAN_DB_URL=postgresql://atman:secret@localhost:5432/atman
# DATABASE_URL=postgresql://atman:secret@localhost:5432/atman

# Individual connection params (used when ATMAN_DB_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=atman
POSTGRES_PASSWORD=secret
POSTGRES_DB=atman

# =============================================================================
# Memory backend
# =============================================================================

# Backend for factual memory: postgres | file | inmemory  (default: file)
ATMAN_MEMORY_BACKEND=file

# =============================================================================
# Embedding
# =============================================================================

# Embedding backend: ollama | flag | mock  (default: ollama)
EMBEDDING_BACKEND=ollama

# Embedding model name
# EMBEDDING_MODEL=bge-m3
# OLLAMA_EMBED_MODEL=bge-m3

# Ollama host for embeddings
EMBEDDING_OLLAMA_HOST=http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Reflection backend
# =============================================================================

# Reflection model backend: openai | anthropic | mock  (default: openai)
ATMAN_REFLECTION_BACKEND=openai

# =============================================================================
# Optional — LLM tuning
# =============================================================================

# Request timeout in seconds
# ATMAN_LLM_TIMEOUT=60

# Number of retries on failure
# ATMAN_LLM_MAX_RETRIES=3

# =============================================================================
# Optional — Anthropic
# =============================================================================

# ANTHROPIC_API_KEY=sk-ant-...
# ATMAN_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ATMAN_ANTHROPIC_MAX_TOKENS=8192

# =============================================================================
# Optional — Agent workspace and session
# =============================================================================

# Workspace directory (default: ~/.atman)
# ATMAN_AGENT_WORKSPACE=~/.atman

# Session debug log path
# ATMAN_SESSION_LOG=~/.atman/session.log
# ATMAN_SESSION_LOG_FILE=~/.atman/session.log

# Enable debug logging
# ATMAN_DEBUG_LOG=1

# Current agent UUID (required for Postgres row-level security)
# ATMAN_CURRENT_AGENT=00000000-0000-0000-0000-000000000000

# =============================================================================
# Optional — Feature flags
# =============================================================================

# Enable GLiNER+MiniLM linguistic analysis
# ATMAN_LINGUISTIC_ENABLED=1

# Enable skill manager
# ATMAN_SKILLS_ENABLED=1

# =============================================================================
# Optional — Observability (Sentry)
# =============================================================================

# Controls how much Sentry telemetry is collected.
# off     — no Sentry, zero overhead (good for local unit-test runs)
# minimal — errors + AI-route traces at 100 %, 10 % elsewhere (production default)
# debug   — 100 % tracing + profiling + Spotlight UI (dev default)
# verbose — debug + SDK self-logging + locals capture (deep diagnostics)
ATMAN_OBS_LEVEL=debug

# Sentry project DSN (leave blank to disable Sentry regardless of OBS_LEVEL)
SENTRY_DSN=

# "development" | "staging" | "production"
SENTRY_ENVIRONMENT=dev

# Optional: pin the Sentry release tag to a git SHA / version string
# SENTRY_RELEASE=

# Set to 1 to allow prompt/completion text to reach Sentry in debug/verbose mode.
# Disabled by default; EventScrubber strips prompt fields client-side.
# ATMAN_SEND_PROMPTS=0

# =============================================================================
# Optional — Hugging Face
# =============================================================================

# Local cache directory for Hugging Face models (FlagEmbedding, GLiNER)
# HF_HOME=~/.cache/huggingface

# =============================================================================
# Legacy aliases (still accepted, prefer the ATMAN_* equivalents above)
# =============================================================================

# AGENT_LLM_BASE_URL=http://localhost:8081/v1
# AGENT_LLM_MODEL=gemma3:27b-it-qat
# AGENT_LLM_API_KEY=sk-no-key
